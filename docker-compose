version: '3.8'

services:
  openclaw:
    image: "coollabsio/openclaw:2026.2.6"
    restart: unless-stopped
    environment:
      # ════════════════════════════════════════════════════════════════════
      # 1. LA JAULA: CAPA DE SEGURIDAD NEMOCLAW (OPEN_SHELL)
      # Este modelo NO interactúa con el usuario. Solo audita comandos.
      # ════════════════════════════════════════════════════════════════════
      - NEMOCLAW_SANDBOX_NAME=alianedos-core
      - NEMOCLAW_NON_INTERACTIVE=1
      - NEMOCLAW_POLICY_MODE=custom # Obliga a OpenShell a ser estricto
      - NEMOCLAW_PROVIDER=nim
      - NEMOCLAW_MODEL=nvidia/nemotron-4-340b-instruct # El alcaide
      
      # Credenciales exclusivas para el motor de seguridad de NemoClaw
      - NVIDIA_API_KEY=${NVIDIA_API_KEY}
      - OPENAI_API_KEY=${NVIDIA_API_KEY}
      - OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

      # ════════════════════════════════════════════════════════════════════
      # 2. LOS CEREBROS: AGENTES DE ALIANED OS (Joseias, Tony, PM, Spirit)
      # Estas APIs alimentan el entorno para que configures los roles en la UI.
      # ════════════════════════════════════════════════════════════════════
      - GEMINI_API_KEY=${GEMINI_API_KEY}
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
      - ZAI_API_KEY=${ZAI_API_KEY}
      - MINIMAX_API_KEY=${MINIMAX_API_KEY}

      # ════════════════════════════════════════════════════════════════════
      # 3. SISTEMA Y RED
      # ════════════════════════════════════════════════════════════════════
      - AUTH_USERNAME=${AUTH_USERNAME}
      - AUTH_PASSWORD=${AUTH_PASSWORD}
      - OPENCLAW_GATEWAY_TOKEN=${OPENCLAW_GATEWAY_TOKEN}
      - TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
      - PORT=8080
      - OPENCLAW_GATEWAY_PORT=18789
      - OPENCLAW_GATEWAY_BIND=loopback
      - OPENCLAW_STATE_DIR=/data/.openclaw
      - OPENCLAW_WORKSPACE_DIR=/data/workspace
      - BROWSER_CDP_URL=http://browser:9223
      - BROWSER_DEFAULT_PROFILE=openclaw
      - BROWSER_EVALUATE_ENABLED=true
      - BROWSER_SNAPSHOT_MODE=efficient
      - BROWSER_REMOTE_TIMEOUT_MS=1500
      - BROWSER_REMOTE_HANDSHAKE_TIMEOUT_MS=3000
      - HOOKS_ENABLED=true # Necesario para las políticas pre y post ejecución

    ports:
      - "8080:8080"
    volumes:
      - joseias-data:/data
    depends_on:
      browser:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://127.0.0.1:8080/healthz"]
      interval: 10s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 8g
        reservations:
          memory: 1g

  browser:
    image: "coollabsio/openclaw-browser:latest"
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=America/Santo_Domingo
      - CHROME_CLI=--remote-debugging-port=9222
    volumes:
      - browser-data:/config
    shm_size: 2g
    deploy:
      resources:
        limits:
          memory: 3g
        reservations:
          memory: 512m
    healthcheck:
      test: ["CMD-SHELL", "bash -c ':> /dev/tcp/127.0.0.1/9222' || exit 1"]
      interval: 5s
      timeout: 5s
      retries: 10

volumes:
  joseias-data:
    driver: local
  browser-data:
    driver: local
